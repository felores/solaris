{
  "name": "sinapso",
  "version": "1.0.1",
  "description": "Sinapso — your Obsidian vault or Open Knowledge Format bundle as a navigable 3D universe.",
  "type": "module",
  "main": "desktop/dist/main.cjs",
  "bin": {
    "sinapso": "dist/cli.cjs"
  },
  "files": [
    "dist/",
    "web/dist/",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felores/sinapso.git"
  },
  "homepage": "https://github.com/felores/sinapso#readme",
  "bugs": {
    "url": "https://github.com/felores/sinapso/issues"
  },
  "keywords": [
    "obsidian",
    "knowledge-graph",
    "3d",
    "visualization",
    "three.js",
    "second-brain",
    "force-graph",
    "open-knowledge-format",
    "okf"
  ],
  "scripts": {
    "scan": "tsx scanner/scan.ts",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:server:network": "TAILSCALE_HOST=$(node scripts/tailscale-host.mjs) SINAPSO_HOST=0.0.0.0 tsx watch server/index.ts",
    "dev:web": "vite web",
    "dev:web:network": "vite web --host 0.0.0.0",
    "dev:network": "concurrently \"npm:dev:server:network\" \"npm:dev:web:network\"",
    "build": "vite build web",
    "build:cli": "esbuild bin/cli.ts --bundle --platform=node --format=cjs --external:express --outfile=dist/cli.cjs",
    "start": "tsx server/index.ts",
    "desktop:build": "vite build web && esbuild desktop/main.ts --bundle --platform=node --format=cjs --external:electron --external:express --outfile=desktop/dist/main.cjs",
    "desktop": "npm run desktop:build && electron .",
    "dist:desktop": "npm run desktop:build && electron-builder --win",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "check": "biome check . --diagnostic-level=error",
    "prepublishOnly": "npm run typecheck && npm run build && npm run build:cli",
    "mcp": "tsx server/mcp.ts"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "dompurify": "^3.4.12",
    "exa-js": "2.16.0",
    "express": "^5.1.0",
    "sqlite-vec": "^0.1.9",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "3d-force-graph": "^1.77.0",
    "concurrently": "^9.0.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "marked": "^15.0.0",
    "minisearch": "^7.2.0",
    "supertest": "^7.1.0",
    "three": "0.184.0",
    "three-spritetext": "^1.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-language-server": "^5.3.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.felo.sinapso",
    "productName": "Sinapso",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/dist/**",
      "web/dist/**",
      "THIRD_PARTY_LICENSES.md"
    ],
    "asarUnpack": [
      "web/dist/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
